  "tokenColors": [

    // ── BASE ────────────────────────────────────────────────────────────────────

    {
      "name": "Global settings",
      "settings": {
        "foreground": "#263238"
      }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#43A047"
      }
    },
    {
      "name": "String Escape",
      "scope": "constant.character.escape, text.html constant.character.entity.named",
      "settings": {
        "foreground": "#263238"
      }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation, constant.other.symbol",
      "settings": {
        "foreground": "#0288D1"
      }
    },
    {
      "name": "Boolean",
      "scope": "constant.language.boolean",
      "settings": {
        "foreground": "#AD1457"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#BF360C"
      }
    },
    {
      "name": "Variable",
      "scope": "variable, variable.parameter, support.variable, variable.language, support.constant, meta.definition.variable entity.name.function, meta.function-call.arguments",
      "settings": {
        "foreground": "#37474F"
      }
    },
    {
      "name": "Keyword",
      "scope": "keyword, modifier, variable.language.this, support.type.object, constant.language",
      "settings": {
        "foreground": "#0288D1"
      }
    },
    {
      "name": "Keyword Control",
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#0263d1",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Other Keyword",
      "scope": "keyword.other",
      "settings": {
        "foreground": "#BF360C"
      }
    },
    {
      "name": "Storage",
      "scope": "storage.type, storage.modifier, storage.control",
      "settings": {
        "foreground": "#8E24AA"
      }
    },
    {
      "name": "Constant keywords",
      "scope": "constant.keyword",
      "settings": {
        "foreground": "#0288D1",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant Placeholder",
      "scope": ["constant.other.placeholder"],
      "settings": {
        "foreground": "#C62828"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Template expression",
      "scope": "template.expression.begin, template.expression.end, punctuation.definition.template-expression.begin, punctuation.definition.template-expression.end",
      "settings": {
        "foreground": "#0288D1"
      }
    },
    {
      "name": "Reset embedded/template expression colors",
      "scope": "meta.embedded, source.groovy.embedded, meta.template.expression",
      "settings": {
        "foreground": "#263238"
      }
    },
    {
      "name": "Markup Underline",
      "scope": ["markup.underline"],
      "settings": {
        "fontStyle": "underline"
      }
    },

    // ── COMMENTS ────────────────────────────────────────────────────────────────

    {
      "name": "Comment",
      "scope": "comment",
      "settings": {
        "foreground": "#90A4AE",
        "fontStyle": ""
      }
    },
    {
      "name": "Comment punctuation",
      "scope": "comment punctuation.definition.comment, string.quoted.docstring",
      "settings": {
        "foreground": "#90A4AE",
        "fontStyle": ""
      }
    },

    // ── FUNCTIONS ───────────────────────────────────────────────────────────────

    {
      "name": "Function call",
      "scope": "entity.name.function, support.function",
      "settings": {
        "foreground": "#1976D2"
      }
    },
    {
      "name": "Function definition",
      "scope": "meta.function entity.name.function",
      "settings": {
        "foreground": "#1976D2"
      }
    },
    {
      "name": "Function call (named)",
      "scope": "entity.name.function.call",
      "settings": {
        "foreground": "#1976D2"
      }
    },
    {
      "name": "Class method",
      "scope": "meta.definition.method entity.name.function",
      "settings": {
        "foreground": "#C62828"
      }
    },
    {
      "name": "Class variable",
      "scope": "variable.object.property, meta.field.declaration entity.name.function",
      "settings": {
        "foreground": "#C62828"
      }
    },

    // ── TYPES & CLASSES ─────────────────────────────────────────────────────────

    {
      "name": "Type",
      "scope": "support.type, constant.other.key, entity.name.type, entity.other.inherited-class, entity.other",
      "settings": {
        "foreground": "#E65100"
      }
    },
    {
      "name": "Class",
      "scope": "entity.name, entity.name.type.class, support.type, support.class, meta.use",
      "settings": {
        "foreground": "#E65100"
      }
    },
    {
      "name": "Modules",
      "scope": "support.module, support.node",
      "settings": {
        "foreground": "#C62828",
        "fontStyle": "italic"
      }
    },

    // ── MARKUP & DIFF ───────────────────────────────────────────────────────────

    {
      "name": "Markup Deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#C62828"
      }
    },
    {
      "name": "Markup Inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#43A047"
      }
    },

    // ── LANGUAGE: JavaScript / TypeScript ───────────────────────────────────────

    {
      "name": "JavaScript Object Variable",
      "scope": "variable.other.object.js",
      "settings": {
        "foreground": "#E65100"
      }
    },
    {
      "name": "JSX Text",
      "scope": "meta.jsx.children, SXNested",
      "settings": {
        "foreground": "#263238"
      }
    },
    {
      "name": "JSX Components name",
      "scope": "support.class.component",
      "settings": {
        "foreground": "#E65100"
      }
    },

    // ── LANGUAGE: CSS ───────────────────────────────────────────────────────────

    {
      "name": "CSS class",
      "scope": "entity.other.attribute-name.class",
      "settings": {
        "foreground": "#E65100"
      }
    },
    {
      "name": "CSS ID",
      "scope": "entity.other.attribute-name.id",
      "settings": {
        "foreground": "#BF360C"
      }
    },
    {
      "name": "CSS tag",
      "scope": "source.css entity.name.tag",
      "settings": {
        "foreground": "#E65100"
      }
    },
    {
      "name": "CSS properties",
      "scope": "support.type.property-name.css",
      "settings": {
        "foreground": "#455A64"
      }
    },

    // ── LANGUAGE: HTML ───────────────────────────────────────────────────────────

    {
      "name": "HTML tag outer",
      "scope": "meta.tag, punctuation.definition.tag",
      "settings": {
        "foreground": "#0288D1"
      }
    },
    {
      "name": "HTML tag inner",
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#C62828"
      }
    },
    {
      "name": "HTML tag attribute",
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#8E24AA"
      }
    },
    {
      "name": "HTML entities",
      "scope": "punctuation.definition.entity.html",
      "settings": {
        "foreground": "#263238"
      }
    },

    // ── LANGUAGE: JSON ───────────────────────────────────────────────────────────

    {
