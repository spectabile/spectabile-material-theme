  "semanticTokenColors": {
    // JavaScript / TypeScript — existing
    "variable.defaultLibrary:javascript": { "foreground": "#f0e2a5" },

    // Universal tokens
    "enumMember":        { "foreground": "#80CBC4" },
    "boolean":           { "foreground": "#ff9cac" },
    "number":            { "foreground": "#F78C6C" },
    "variable.constant": { "foreground": "#89DDFF" },
    "macro":             { "foreground": "#C792EA" },
    "interface":         { "foreground": "#FFCB6B" },
    "typeParameter":     { "foreground": "#FFCB6B" },

    // TOML
    "tomlArrayKey": { "foreground": "#82AAFF", "fontStyle": "" },
    "tomlTableKey": { "foreground": "#82AAFF", "fontStyle": "" },

    // JavaScript / TypeScript — prevent const from inheriting variable color
    "variable.readonly:javascript":  { "foreground": "#EEFFFF" },
    "variable.readonly:typescript":  { "foreground": "#EEFFFF" },
    "property.readonly:javascript":  { "foreground": "#EEFFFF" },
    "property.readonly:typescript":  { "foreground": "#EEFFFF" },

    // Python
    "class:python":              { "foreground": "#FFCB6B" },
    "class.builtin:python":      { "foreground": "#C792EA" },
    "function.decorator:python": { "foreground": "#F78C6C" },
    "variable.typeHint:python":  { "foreground": "#FFCB6B" }
  }
